{
    "manifest_version": 3,
    "name": "ArthasMod",
    "version": "1.4.1",
    "description": "A modern costume for isy.ksr.ch made by Arthas1811",
    "host_permissions": [
        "*://isy.ksr.ch/*",
        "*://isy-api.ksr.ch/*",
        "*://*.ksr.ch/*",
        "https://raw.githubusercontent.com/*",
        "https://api.github.com/*"
    ],
    "permissions": [
        "cookies",
        "storage"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://isy.ksr.ch/*"
            ],
            "js": [
                "main-world-cache.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "*://isy.ksr.ch/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "styles.css"
            ],
            "matches": [
                "*://isy.ksr.ch/*"
            ]
        }
    ]
}
